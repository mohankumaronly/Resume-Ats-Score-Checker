{
  "info": {
    "name": "Resume Analyzer API - Passwordless Auth",
    "description": "Complete API for resume analysis with OTP-based passwordless authentication using Groq AI. Version 2.0 - Added Job Description Matching.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "4.0.0"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Send OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"OTP sent successfully\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.message).to.include('OTP sent');",
                  "    pm.expect(jsonData).to.have.property('email');",
                  "    pm.expect(jsonData).to.have.property('newUser');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"rockrangerz801@gmail.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/send-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "send-otp"]
            },
            "description": "Step 1: Send OTP to email. Only email is required."
          },
          "response": []
        },
        {
          "name": "2. Verify OTP & Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Login successful\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.message).to.include('Login successful');",
                  "    pm.expect(jsonData.verified).to.be.true;",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "    pm.expect(jsonData).to.have.property('email');",
                  "});",
                  "",
                  "if (pm.response.json().token) {",
                  "    pm.environment.set('auth_token', pm.response.json().token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"rockrangerz801@gmail.com\",\n    \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify-otp",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "verify-otp"]
            },
            "description": "Step 2: Verify OTP and get JWT token. Replace '123456' with the actual OTP from your email."
          },
          "response": []
        },
        {
          "name": "3. Resend OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"OTP resent successfully\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.message).to.include('New OTP sent');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/resend-otp?email=rockrangerz801@gmail.com",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "resend-otp"],
              "query": [
                {
                  "key": "email",
                  "value": "rockrangerz801@gmail.com"
                }
              ]
            },
            "description": "Step 3: Resend OTP if the previous one expired."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Resume Analysis",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contains success message\", function () {",
                  "    pm.response.to.have.body(\"Resume Analyzer API is running!\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/resume/health",
              "host": ["{{base_url}}"],
              "path": ["api", "resume", "health"]
            }
          },
          "response": []
        },
        {
          "name": "1. Analyze Resume (Generic)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('atsScore');",
                  "    pm.expect(jsonData).to.have.property('overallRating');",
                  "    pm.expect(jsonData).to.have.property('summary');",
                  "    pm.expect(jsonData).to.have.property('detailedFeedback');",
                  "    pm.expect(jsonData).to.have.property('sectionScores');",
                  "    pm.expect(jsonData).to.have.property('strengths');",
                  "    pm.expect(jsonData).to.have.property('weaknesses');",
                  "    pm.expect(jsonData).to.have.property('suggestions');",
                  "    pm.expect(jsonData).to.have.property('missingKeywords');",
                  "    pm.expect(jsonData).to.have.property('recommendedSkills');",
                  "    pm.expect(jsonData).to.have.property('atsFriendly');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "resume",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/resume/analyze",
              "host": ["{{base_url}}"],
              "path": ["api", "resume", "analyze"]
            },
            "description": "📄 Upload a PDF resume for generic AI analysis. Click 'Select Files' to choose your PDF. Requires authentication token."
          },
          "response": []
        },
        {
          "name": "2. Analyze Resume with Job Description (NEW)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has job match fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('atsScore');",
                  "    pm.expect(jsonData).to.have.property('matchScore');",
                  "    pm.expect(jsonData).to.have.property('keywordMatchRate');",
                  "    pm.expect(jsonData).to.have.property('missingKeywords');",
                  "    pm.expect(jsonData).to.have.property('skillsGap');",
                  "    pm.expect(jsonData).to.have.property('experienceMatch');",
                  "    pm.expect(jsonData).to.have.property('educationMatch');",
                  "    pm.expect(jsonData).to.have.property('strengths');",
                  "    pm.expect(jsonData).to.have.property('weaknesses');",
                  "    pm.expect(jsonData).to.have.property('suggestions');",
                  "});",
                  "",
                  "pm.test(\"Match Score is between 0 and 100\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.matchScore).to.be.at.least(0);",
                  "    pm.expect(jsonData.matchScore).to.be.at.most(100);",
                  "});",
                  "",
                  "pm.test(\"Skills gap has required, found, missing\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.skillsGap).to.have.property('required');",
                  "    pm.expect(jsonData.skillsGap).to.have.property('found');",
                  "    pm.expect(jsonData.skillsGap).to.have.property('missing');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "resume",
                  "type": "file",
                  "src": ""
                },
                {
                  "key": "jobDescription",
                  "type": "text",
                  "value": "Senior Full Stack Developer\n\nWe are looking for a Senior Full Stack Developer with 5+ years of experience in Java, Spring Boot, and React. The ideal candidate should have strong experience with:\n\n- Java 17+, Spring Boot, Spring Security\n- React.js, TypeScript, Tailwind CSS\n- PostgreSQL, MongoDB\n- AWS (EC2, S3, RDS) or Azure\n- Docker, Kubernetes\n- CI/CD pipelines (Jenkins, GitHub Actions)\n- Microservices architecture\n- REST API development\n\nRequirements:\n- Bachelor's degree in Computer Science or related field\n- 5+ years of full-stack development experience\n- Strong problem-solving and communication skills\n- Experience leading technical teams is a plus"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/resume/analyze-with-job",
              "host": ["{{base_url}}"],
              "path": ["api", "resume", "analyze-with-job"]
            },
            "description": "🎯 NEW: Upload a PDF resume and paste a job description for targeted ATS analysis. Returns match score, keyword match rate, skills gap analysis, and job-specific suggestions. Requires authentication token."
          },
          "response": [
            {
              "name": "Success Response",
              "code": 200,
              "body": "{\n    \"atsScore\": 82,\n    \"matchScore\": 76,\n    \"overallRating\": \"Very Good\",\n    \"summary\": \"Strong technical foundation with good full-stack experience. Missing some cloud and DevOps skills required for the role.\",\n    \"keywordMatchRate\": 72,\n    \"missingKeywords\": [\n        \"AWS\",\n        \"Docker\",\n        \"Kubernetes\",\n        \"CI/CD\",\n        \"Microservices\"\n    ],\n    \"skillsGap\": {\n        \"required\": [\"Java 17+\", \"Spring Boot\", \"React\", \"PostgreSQL\", \"AWS\", \"Docker\", \"Kubernetes\", \"CI/CD\", \"Microservices\"],\n        \"found\": [\"Java\", \"Spring Boot\", \"React\", \"PostgreSQL\"],\n        \"missing\": [\"AWS\", \"Docker\", \"Kubernetes\", \"CI/CD\", \"Microservices\"]\n    },\n    \"experienceMatch\": \"3 years of experience found vs 5+ years required. Good progression but needs more senior-level examples.\",\n    \"educationMatch\": \"Bachelor's degree in Computer Science matches the requirement.\",\n    \"sectionScores\": {\n        \"formatting\": 90,\n        \"technicalSkills\": 85,\n        \"experience\": 75,\n        \"projects\": 88,\n        \"education\": 80,\n        \"keywords\": 72\n    },\n    \"strengths\": [\n        \"Strong Java and Spring Boot expertise\",\n        \"Good full-stack development skills\",\n        \"Solid project experience\"\n    ],\n    \"weaknesses\": [\n        \"Limited cloud experience (AWS/Azure)\",\n        \"No containerization experience (Docker/Kubernetes)\",\n        \"Missing CI/CD pipeline experience\"\n    ],\n    \"suggestions\": [\n        \"Add AWS experience or get AWS certification\",\n        \"Learn Docker and Kubernetes fundamentals\",\n        \"Set up a CI/CD pipeline using GitHub Actions\",\n        \"Add microservices experience to your resume\",\n        \"Quantify your achievements with metrics\"\n    ],\n    \"recommendedSkills\": [\n        \"AWS Solutions Architect\",\n        \"Docker and Kubernetes\",\n        \"Jenkins or GitHub Actions\",\n        \"Redis or caching technologies\"\n    ],\n    \"atsFriendly\": true,\n    \"analysisConfidence\": 88,\n    \"analyzedAt\": \"2026-07-16T10:30:00\"\n}"
            },
            {
              "name": "Error - No File",
              "code": 400,
              "body": "Please upload a valid PDF file."
            },
            {
              "name": "Error - No Job Description",
              "code": 400,
              "body": "Job description is required. Please paste the job description."
            },
            {
              "name": "Error - File Too Large",
              "code": 400,
              "body": "File size exceeds 5MB limit. Please upload a smaller file."
            },
            {
              "name": "Error - Unauthorized",
              "code": 401,
              "body": "{\n    \"error\": \"Unauthorized\",\n    \"message\": \"Full authentication is required to access this resource\"\n}"
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "id": "base_url",
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "id": "auth_token",
      "key": "auth_token",
      "value": "",
      "type": "string"
    }
  ]
}